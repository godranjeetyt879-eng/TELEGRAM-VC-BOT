# Node.js ka lightweight version use kar rahe hain
FROM node:18-alpine

# Container ke andar working directory set kar rahe hain
WORKDIR /app

# Pehle package.json copy karke dependencies install karenge (fast build ke liye)
COPY package*.json ./
RUN npm install

# Ab baaki ka poora code copy karenge
COPY . .

